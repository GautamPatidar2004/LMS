# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES (Vite React App)
# These are exposed to the client browser.
# ==============================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_RAZORPAY_KEY_ID=rzp_test_yourkeyid # Public Razorpay Key ID (needed for Checkout UI modal)

# ==============================================================================
# EDGE FUNCTIONS ENVIRONMENT VARIABLES
# NEVER expose the service key or the Razorpay Key Secret to the frontend!
# Inject these into Supabase Edge Functions using:
# supabase secrets set RAZORPAY_KEY_ID=... RAZORPAY_KEY_SECRET=...
# ==============================================================================
# RAZORPAY_KEY_ID=rzp_test_yourkeyid
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret_never_expose
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_never_expose
